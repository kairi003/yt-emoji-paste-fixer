{
  "manifest_version": 3,
  "name": "YTLive Paste Fixer",
  "version": "1.0",
  "description": "Fix paste functionality in YouTube live chat by handling emoji and text insertion properly",
  "content_scripts": [
    {
      "matches": [ "https://www.youtube.com/live_chat?*" ],
      "js": [ "content.js" ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [ "inject.js" ],
      "matches": [ "https://www.youtube.com/*" ]
    }
  ]
}
