{
  "manifest_version": 3,
  "name": "YT Emoji Paste Fixer",
  "version": "1.1.1",
  "description": "Fix emoji paste issues in YouTube comment or live chat",
  "icons": {
    "16": "/img/icon16.png",
    "32": "/img/icon32.png",
    "48": "/img/icon48.png",
    "128": "/img/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ]
}
